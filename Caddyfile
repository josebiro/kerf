{
	admin off
	auto_https off
	log {
		output stdout
		format console
	}
}

:8000 {
	# Allow large 3MF / STEP uploads
	request_body {
		max_size 100MB
	}

	# Security headers — applied to all responses (API + frontend).
	# CSP allows Supabase calls (auth, storage, realtime); tighten if a
	# different backend service is ever proxied in front.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; img-src 'self' https://*.supabase.co data: blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:8001
	}

	handle {
		reverse_proxy 127.0.0.1:3000
	}
}
