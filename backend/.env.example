# Backend runtime environment.
#
# Copy to backend/.env and fill in real values. docker-compose.yml
# loads this file via env_file: ./backend/.env. Never commit .env.

# Supabase project URL (https://<ref>.supabase.co)
SUPABASE_URL=

# Supabase anon (public) API key — used to construct user-scoped
# clients for RLS-protected tables and the projects storage bucket.
# Project Settings → API → anon public.
SUPABASE_ANON_KEY=

# Supabase service-role key — used ONLY for system-level reads
# (suppliers, supplier_prices catalog) and JWT verification. Never
# touches user-owned data; that goes through user-scoped clients.
# Project Settings → API → service_role secret.
SUPABASE_SERVICE_KEY=

# Optional: comma-separated CORS allow-list. In production set this
# to your canonical origin, e.g. https://kerf.example.com.
# Defaults to localhost dev origins if unset.
# ALLOWED_ORIGINS=https://kerf.example.com
